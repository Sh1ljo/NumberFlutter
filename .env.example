# Copy to assets/.env and fill in (same keys as below).
# The app loads assets/.env at startup via flutter_dotenv.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_PROJECT_ID=
# Optional; default is com.example.number_flutter://login-callback (must match Supabase redirect allow list)
SUPABASE_OAUTH_REDIRECT_URL=
# Required for native Google Sign-In on Android/iOS. Use the OAuth Web application client ID from Google Cloud.
GOOGLE_WEB_CLIENT_ID=
